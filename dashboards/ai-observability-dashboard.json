{
  "version": 21,
  "variables": [
    {
      "key": "Model",
      "visible": true,
      "type": "query",
      "version": 2,
      "editable": true,
      "input": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| summarize models = collectDistinct(gen_ai.request.model)\n| expand models\n| sort models",
      "multiple": false
    }
  ],
  "tiles": {
    "1": {
      "title": "Total LLM Requests",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model\n| summarize count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "recordField": "count()",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "2": {
      "type": "markdown",
      "content": "## \uD83E\uDD16 AI Observability — BizObs Forge\n*Powered by Ollama + OpenTelemetry GenAI Semantic Conventions*"
    },
    "3": {
      "type": "markdown",
      "content": "## $Model Requests"
    },
    "4": {
      "title": "Chat Completions",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| filter llm.request.type == \"chat\"\n| summarize count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "label": "Chat Requests",
          "recordField": "count()",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "5": {
      "title": "Completion Requests",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| filter llm.request.type == \"completion\"\n| summarize count()",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "label": "Completion Requests",
          "recordField": "count()",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "6": {
      "title": "Error Rate",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| summarize total = count(), errors = countIf(span.status_code == \"ERROR\")\n| fieldsAdd errorRate = 100.0 * errors / total",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "label": "Error %",
          "recordField": "errorRate",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        },
        "thresholds": [
          { "field": "errorRate", "title": "", "isEnabled": true, "rules": [
            { "color": { "Default": "#14a8f5" }, "comparator": "<=", "value": 1 },
            { "color": { "Default": "#f5d30f" }, "comparator": "<=", "value": 5 },
            { "color": { "Default": "#dc3545" }, "comparator": ">", "value": 5 }
          ]}
        ]
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "7": {
      "type": "markdown",
      "content": "## $Model Token Usage"
    },
    "8": {
      "title": "Prompt Tokens",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model or gen_ai.response.model == $Model\n| summarize promptTokens = sum(gen_ai.usage.prompt_tokens)",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "recordField": "promptTokens",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "9": {
      "title": "Completion Tokens",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model or gen_ai.response.model == $Model\n| summarize completionTokens = sum(gen_ai.usage.completion_tokens)",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "recordField": "completionTokens",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "10": {
      "title": "Total Tokens",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model or gen_ai.response.model == $Model\n| summarize totalTokens = sum(gen_ai.usage.prompt_tokens) + sum(gen_ai.usage.completion_tokens)",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "labelMode": "none",
          "recordField": "totalTokens",
          "prefixIcon": "",
          "trend": { "isVisible": true }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "11": {
      "title": "Token Consumption Over Time (Dynatrace Intelligence Forecast)",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model or gen_ai.response.model == $Model\n| fieldsAdd promptTok = coalesce(asLong(gen_ai.usage.prompt_tokens), 0)\n| fieldsAdd completionTok = coalesce(asLong(gen_ai.usage.completion_tokens), 0)\n| makeTimeseries tokenConsumption = sum(promptTok + completionTok), interval: 1m",
      "visualization": "davis",
      "visualizationSettings": {
        "autoSelectVisualization": false,
        "chartSettings": {
          "gapPolicy": "connect",
          "fieldMapping": {
            "timestamp": "timeframe",
            "leftAxisValues": ["tokenConsumption"]
          },
          "valueRepresentation": "absolute"
        },
        "singleValue": {
          "trend": { "isVisible": true, "trendType": "auto" },
          "labelMode": "none"
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": {
        "enabled": true,
        "componentState": {
          "selectedAnalyzerName": "dt.statistics.ui.ForecastAnalyzer",
          "inputData": {
            "dt.statistics.ui.ForecastAnalyzer": {
              "generalParameters": {
                "timeframe": { "startTime": "now-7d", "endTime": "now" },
                "resolveDimensionalQueryData": true,
                "logVerbosity": "INFO"
              },
              "forecastHorizon": 10,
              "forecastOffset": 1,
              "query": {
                "expression": "fetch spans\n| filter gen_ai.system == \"ollama\"\n| filter gen_ai.request.model == $Model or gen_ai.response.model == $Model\n| fieldsAdd promptTok = coalesce(asLong(gen_ai.usage.prompt_tokens), 0)\n| fieldsAdd completionTok = coalesce(asLong(gen_ai.usage.completion_tokens), 0)\n| makeTimeseries tokenConsumption = sum(promptTok + completionTok), interval: 1m"
              }
            }
          }
        },
        "davisVisualization": { "isAvailable": true }
      }
    },
    "12": {
      "type": "markdown",
      "content": "## Response Performance"
    },
    "13": {
      "title": "Status Distribution",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| fieldsAdd status = if(span.status_code == \"ERROR\", \"Error\", else: \"Success\")\n| summarize count(), by: {status}",
      "visualization": "pieChart",
      "visualizationSettings": {
        "chartSettings": {
          "circleChartSettings": {
            "groupingThresholdType": "relative",
            "groupingThresholdValue": 0,
            "valueType": "relative"
          }
        }
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "14": {
      "title": "Avg Response Time by Request Type",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| filter llm.request.type != \"\"\n| fieldsKeep duration, gen_ai.request.model, llm.request.type, end_time\n| makeTimeseries avg(duration), by: {llm.request.type}, time: end_time",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect",
          "curve": "smooth",
          "fieldMapping": {
            "timestamp": "timeframe",
            "leftAxisValues": ["avg(duration)"]
          }
        },
        "unitsOverrides": [
          {
            "identifier": "avg(duration)",
            "unitCategory": "time",
            "baseUnit": "nanosecond",
            "displayUnit": null,
            "decimals": 2,
            "suffix": "",
            "delimiter": false,
            "added": 1726557632369
          }
        ]
      },
      "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
      "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
    },
    "15": {
      "title": "Response Duration (ms)",
      "type": "data",
      "query": "fetch spans\n| filter gen_ai.system == \"ollama\" and gen_ai.request.model == $Model\n| filter isNotNull(gen_ai.response.duration_ms)\n| makeTimeseries avg_ms = avg(gen_ai.response.duration_ms), by: {llm.request.type}, interval: 1m",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "gapPolicy": "connect",
          "curve": "smooth",
          "fieldMapping": {
            "timestamp": "timeframe",
